# Required
GITHUB_TOKEN=           # personal access token with 'user:follow' scope
GITHUB_USERNAME=        # your own GitHub login (e.g. jordanhymas)

# Daily limits (conservative defaults — GitHub informal safe limit is ~50/day)
DAILY_FOLLOW_MAX=25
FOLLOW_DELAY_MIN_SEC=45
FOLLOW_DELAY_MAX_SEC=90
CHECKBACK_HOURS=48
MAX_FOLLOWING_TOTAL=400
UNFOLLOW_NON_RECIPROCAL=false

# Discovery filters — tight cap targets small accounts for higher follow-back odds
MIN_FOLLOWERS=10
MAX_FOLLOWERS=50
LANGUAGE=javascript
SEARCH_QUERIES=          # optional comma-separated custom queries (overrides MIN/MAX/LANGUAGE)
