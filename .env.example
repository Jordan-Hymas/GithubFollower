# Required
GITHUB_TOKEN=           # personal access token with 'user:follow' scope
GITHUB_USERNAME=        # your own GitHub login (e.g. jordanhymas)

# Daily limits
DAILY_FOLLOW_MAX=25
FOLLOW_DELAY_MIN_SEC=45
FOLLOW_DELAY_MAX_SEC=90
CHECKBACK_HOURS=48
MAX_FOLLOWING_TOTAL=400
UNFOLLOW_NON_RECIPROCAL=false

# Discovery — target accounts with very few followers for highest follow-back odds
MIN_FOLLOWERS=5
MAX_FOLLOWERS=10
LANGUAGE=javascript
SEARCH_QUERIES=          # optional comma-separated custom queries (overrides MIN/MAX/LANGUAGE)

# Targeting — follow the followers of specific accounts (higher quality than search)
TARGET_ACCOUNTS=         # comma-separated GitHub logins, e.g. sindresorhus,tj

# Quality filters — skip low-quality / bot accounts
MIN_ACCOUNT_AGE_DAYS=30  # skip accounts newer than this (0 = disabled)
MIN_BIO_LENGTH=0         # skip accounts with bio shorter than this (0 = disabled)
MAX_FOLLOW_RATIO=10      # skip if following/followers ratio exceeds this (0 = disabled)

# Whitelist — never unfollow these users
WHITELIST_USERS=         # comma-separated GitHub logins

# Notifications — optional Discord webhook for session summaries
DISCORD_WEBHOOK_URL=
